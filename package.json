    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.42.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "uuid": "^14.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
